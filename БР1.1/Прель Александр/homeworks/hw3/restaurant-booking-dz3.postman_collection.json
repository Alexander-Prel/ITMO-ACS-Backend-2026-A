      "key": "userPassword",
      "value": "StrongPass123",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "cuisineId",
      "value": "",
      "type": "string"
