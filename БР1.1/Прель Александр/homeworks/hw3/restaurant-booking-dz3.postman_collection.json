    {
      "name": "13. Создание бронирования",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const date = new Date();",
              "date.setUTCDate(date.getUTCDate() + 30 + (Date.now() % 20));",
              "const yyyy = date.getUTCFullYear();",
              "const mm = String(date.getUTCMonth() + 1).padStart(2, '0');",
              "const dd = String(date.getUTCDate()).padStart(2, '0');",
              "pm.collectionVariables.set('reservationDate', `${yyyy}-${mm}-${dd}`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Бронирование создано', function () { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "pm.test('Статус бронирования confirmed', function () { pm.expect(json.status).to.eql('confirmed'); });",
              "pm.collectionVariables.set('reservationId', String(json.reservationId));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
