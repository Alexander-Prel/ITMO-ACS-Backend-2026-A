    {
      "name": "07. Поиск ресторанов с фильтрацией и сортировкой",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Список ресторанов получен', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('Найден хотя бы один ресторан', function () { pm.expect(json.items).to.be.an('array').that.is.not.empty; });",
              "const index = Math.floor(Math.random() * json.items.length);",
              "const restaurant = json.items[index];",
              "pm.test('Ресторан содержит рейтинг и ценовую категорию', function () { pm.expect(restaurant).to.have.property('priceCategory'); pm.expect(restaurant).to.have.property('averageRating'); });",
              "pm.collectionVariables.set('restaurantId', String(restaurant.restaurantId));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/restaurants?name=piazza&price_category=medium&sort_by=rating&sort_order=desc&page=1&limit=10",
          "host": [
            "{{baseUrl}}"
