  "item": [
    {
      "name": "01. Проверка доступности API",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('API доступно', function () { pm.response.to.have.status(200); });",
              "pm.test('Статус ok', function () { pm.expect(pm.response.json().status).to.eql('ok'); });"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      }
    },
    {
      "name": "02. Регистрация пользователя",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const stamp = Date.now();",
              "pm.collectionVariables.set('userEmail', `postman.user.${stamp}@example.com`);",
              "pm.collectionVariables.set('userPassword', 'StrongPass123');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Пользователь зарегистрирован', function () { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "pm.test('Получен JWT', function () { pm.expect(json.accessToken).to.be.a('string').and.not.empty; });",
              "pm.test('Вернулся профиль пользователя', function () { pm.expect(json.user.email).to.eql(pm.collectionVariables.get('userEmail')); });",
              "pm.collectionVariables.set('accessToken', json.accessToken);",
              "pm.collectionVariables.set('userId', String(json.user.userId));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Александр\",\n  \"lastName\": \"Прель\",\n  \"email\": \"{{userEmail}}\",\n  \"phone\": \"+79995550123\",\n  \"password\": \"{{userPassword}}\"\n}"
        }
      }
    },
    {
      "name": "03. Вход пользователя",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Вход выполнен', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('Получен новый JWT', function () { pm.expect(json.accessToken).to.be.a('string').and.not.empty; });",
              "pm.collectionVariables.set('accessToken', json.accessToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
